# ============================================================================
#  Algorithm CRM — Environment Variables
#  Copy this file to .env.local and fill in the values
# ============================================================================

# Supabase — from your project dashboard at https://supabase.com/dashboard
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Service role key (KEEP SECRET — never expose to browser)
# Used by the cron job to process alerts for all users
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Cron secret — generate any random string. Used to authenticate Vercel Cron calls.
# Generate with: openssl rand -base64 32
CRON_SECRET=
